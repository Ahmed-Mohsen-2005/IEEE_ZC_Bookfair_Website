generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("visitor") // "visitor" | "publisher" | "admin"
  avatar    String?
  publisherId String? // if role is publisher, which publisher they manage
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userBooks UserBook[]
}

model Publisher {
  id          String @id @default(cuid())
  name        String
  slug        String @unique // "general-egyptian", "dar-al-maaref", "national-library", "al-ahram"
  tagline     String
  description String
  accentColor String // secondary accent color
  logoUrl     String?
  bookCount   Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  books       Book[]
}

model Book {
  id          String   @id @default(cuid())
  title       String
  author      String
  description String
  genre       String
  language    String   @default("Arabic")
  year        Int
  coverUrl    String?
  pdfUrl      String?
  publisherId String
  publisher   Publisher @relation(fields: [publisherId], references: [id])
  readCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userBooks   UserBook[]
}

model UserBook {
  id       String @id @default(cuid())
  userId   String
  bookId   String
  status   String // "read" | "want-to-read"
  user     User   @relation(fields: [userId], references: [id])
  book     Book   @relation(fields: [bookId], references: [id])
  addedAt  DateTime @default(now())

  @@unique([userId, bookId])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  speaker     String?
  date        DateTime
  duration    String   @default("1 hour")
  type        String   @default("workshop") // "workshop" | "panel" | "talk"
  publisherId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
